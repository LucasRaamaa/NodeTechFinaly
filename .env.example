# Puerto donde se levanta el servidor
PORT=3000

# Configuracion del proyecto de Firebase (Firestore)
# Estos valores se obtienen desde la consola de Firebase > Configuracion del proyecto > Tus apps
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Configuracion de JWT
JWT_SECRET=
JWT_EXPIRES_IN=1h

# Credenciales del usuario administrador utilizadas en el login
ADMIN_EMAIL=
ADMIN_PASSWORD=
